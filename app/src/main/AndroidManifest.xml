<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FFmpegAVTutorial">
        <activity
            android:name=".basic.AvFrameGuideActivity"
            android:exported="false" />
        <activity
            android:name=".basic.AvBufferGuideActivity"
            android:exported="false" />
        <activity
            android:name=".basic.AvRationalGuideActivity"
            android:exported="false" />
        <activity
            android:name=".container.RtmpPushActivity"
            android:exported="false" />
        <activity
            android:name=".container.LiveFlvMuxActivity"
            android:exported="false" />
        <activity
            android:name=".container.FlvMuxActivity"
            android:exported="false" />
        <activity
            android:name=".home.FeatureDetailActivity"
            android:exported="false" />
        <activity
            android:name=".basic.FFmpegInfoActivity"
            android:exported="false" />
        <activity
            android:name=".home.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>

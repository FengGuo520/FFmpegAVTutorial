    <string name="feature_camera_preview_title">Camera Preview</string>
    <string name="feature_camera_preview_summary">打开摄像头并做本地预览，验证采集链路与前后摄切换能力。</string>
    <string name="feature_camera_info_title">Camera Info</string>
